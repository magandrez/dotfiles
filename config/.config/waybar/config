      "tooltip-format": "{:%e %B %Y}",
    },
    "cpu": {
        "format": "´ïø  {usage}%  ({load})"
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon0/temp1_input",
        "critical-threshold": 70,
        "format-critical": "{icon} {temperatureC}┬░C",
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["´Ø½", "´ïë", "´Ø®"]
    },
    "memory": {
        "format": "´âë  {}%",
        "interval": 5,
        "exec": "free -h | awk '/Mem:/{printf $3/$2 * 100.0}'",
        "tooltip": true,
     },
    "battery": {
	"interval": 10,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-icons": [
            "<span color=\"#ff5555\">´ëä</span>",
            "<span color=\"#ffb86c\">´ëâ</span>",
            "<span color=\"#f1fa8c\">´ëé</span>",
