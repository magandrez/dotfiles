{
    "layer": "top",
    "position": "top",
    "height": 30,
    "margin": "5 10 5 10",
    "modules-left": ["sway/workspaces", "sway/language"],
    "modules-right": ["cpu","temperature", "memory", "wireplumber", "wireplumber#source", "backlight", "battery", "network", "clock", "tray"],
    "mode": {
	"docked": {
	    "output": ["eDP-1","DP-1"],
 	}
    },
     "sway/workspaces": {
         "disable-scroll": true,
         "disable-markup" : false,
         "format":" {icon} ",
         "format-icons": {
             "1": "´ë®",
             "2": "´äá",
             "3": "´äí",
             "4": "´üÁ",
             "9": "´Çü",
         }
     },
     "sway/language": {
        "format": "{} Ôî¿´©Å",
	"min-length": 5,
	"tooltip": false,
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    },
   "tray": {
        "icon-size": 24,
        "spacing": 3
    },
    "clock": {
        "tooltip": false,
        "interval": 1,
        "format": "<span color=\"#ff5555\">´Çù</span>  {:%H : %M}",
        "format-alt": "<span color=\"#bd93f9\">´ü│</span>   {:%d.%m.%Y}"
    },
    "clock#time": {
        "format": "{:%H:%M}"
    },
    "clock#date": {
