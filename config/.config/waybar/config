        ]
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ´ç½",
        "format-ethernet": "{ifname} ´âü",
        "format-disconnected": "ÔÜá",
        "interval" : 7,
        "on-click": "foot -e 'nmtui'",
        "tooltip": false
    },
    "wireplumber": {
	"format": "{volume}% {icon}",
	"format-muted": "´ÇĞ off",
	"format-icons": ["´ÇĞ", "´Çğ", "´Ç¿"],
	"on-click": "helvum",
	"on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
