{
    "layer": "top",
    "position": "top",
    "height": 30,
    "margin": "5 10 5 10",
    "modules-left": ["sway/workspaces", "sway/language"],
    "modules-right": ["cpu","temperature", "memory", "wireplumber", "wireplumber#source", "backlight", "battery", "network", "clock", "tray"],
    "mode": {
	"docked": {
	    "output": ["eDP-1","DP-1"],
 	}
    },
     "sway/workspaces": {
         "disable-scroll": true,
         "disable-markup" : false,
         "format":" {icon} ",
         "format-icons": {
             "1": "",
             "2": "",
             "3": "",
             "4": "",
             "9": "",
         }
     },
     "sway/language": {
        "format": "{} ⌨️",
	"min-length": 5,
	"tooltip": false,
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    },
   "tray": {
        "icon-size": 24,
        "spacing": 3
    },
    "clock": {
        "tooltip": false,
        "interval": 1,
        "format": "<span color=\"#ff5555\"></span>  {:%H : %M}",
        "format-alt": "<span color=\"#bd93f9\"></span>   {:%d.%m.%Y}"
    },
    "clock#time": {
        "format": "{:%H:%M}"
    },
    "clock#date": {
      "format": "  {:%e %b %Y}",
      "tooltip-format": "{:%e %B %Y}",
    },
    "cpu": {
        "format": "  {usage}%  ({load})"
    },
    "temperature": {
        "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
        "input-filename": "temp1_input",
        "critical-threshold": 70,
        "interval": 5,
        "format": "{icon} {temperatureC}°C",
        "format-icons": ["", "", "!!!"]
    },
    "memory": {
        "format": "  {}%",
        "interval": 5,
        "exec": "free -h | awk '/Mem:/{printf $3/$2 * 100.0}'",
        "tooltip": true,
     },
    "battery": {
	"interval": 10,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-icons": [
            "<span color=\"#ff5555\"></span>",
            "<span color=\"#ffb86c\"></span>",
            "<span color=\"#f1fa8c\"></span>",
            "<span color=\"#50fa7b\"></span>",
            "<span color=\"#50fa7b\"></span>"
        ]
    },
    "network": {
        "format-wifi": "   {essid} ({signalStrength}%)",
        "format-ethernet": "{ifname} ",
        "format-disconnected": "⚠",
        "interval" : 7,
        "on-click": "foot -e 'nmtui'",
        "tooltip": false
    },
    "wireplumber": {
	"format": "{icon} {volume}%",
	"format-muted": " off",
	"format-icons": ["", "", ""],
	"on-click": "helvum",
	"on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
	"scroll-step": 5
    },
    "wireplumber#source": {
	"node-type": "Audio/Source",
	"format": "  {volume}%",
	"format-muted": " off",
	"on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
	"scroll-step": 5
    },
   "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["", "", "", "", "", "", "", "", ""]
   },
}
