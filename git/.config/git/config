	name = Manuel González
	email = manuel@manuel.is
	signingkey = 0C72166F87541FE1
        gpgsign = true
        [includeIf "gitdir:~/workbench/work/"]
                   path = ~/workbench/work/.gitconfig
[push]
	default = current
	autoSetupRemote = true
[alias]
	commend = commit --amend --no-edit
	grog = log --graph --abbrev-commit --decorate --all --format=format:\"%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(dim white) - %an%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n %C(white)%s%C(reset)\"
[pull]
	rebase = true
[rebase]
        autostash = true
[color] 
        diff = auto
        status = auto
        branch = auto
        ui = auto
[fetch]
	prune = true
[commit]
	gpgsign = true
[init]
	defaultbranch = main
[github]
	user = magandrez
[core]
	autocrlf = input
[gpg]
	program = gpg2
[forge]
	remote = origin
[merge]
	conflictstyle = diff3
[branch]
	autosetupmerge = true
[diff]
	submodule = log
